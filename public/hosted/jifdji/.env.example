# ============================================================
#  .env.example — Environment Variables Template
#  انسخ هذا الملف إلى .env وعدّل القيم
#  لا ترفع .env أبداً إلى GitHub!
# ============================================================

# ─── Application ─────────────────────────────────────────────
APP_ENV=production
APP_NAME=Blog System
APP_URL=https://your-app-name.onrender.com

# ─── Database (TiDB Cloud) ────────────────────────────────────
# احصل على هذه القيم من: TiDB Cloud → Connect → PHP
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username
DB_PASS=your_tidb_password
DB_NAME=blog_backend

# SSL — true دائماً مع TiDB Cloud
DB_USE_SSL=true
# مسار ملف ca.pem (ضعه في مجلد ssl/ في المشروع)
DB_SSL_CA=/var/www/html/ssl/ca.pem
